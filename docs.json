{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OwnPay",
  "description": "Self-hosted, enterprise-grade payment orchestrator with multi-brand support, white-label domains, and 100+ payment gateways.",
  "colors": {
    "primary": "#0D9373",
    "light": "#34D399",
    "dark": "#059669"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://ownpay.org/docs"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:site_name": "OwnPay Documentation",
      "og:type": "website",
      "og:title": "OwnPay - Self-Hosted Payment Gateway Platform Documentation",
      "og:description": "Complete documentation for OwnPay, the open-source self-hosted payment orchestrator with multi-brand support, 100+ gateways, and white-label checkout.",
      "og:url": "https://ownpay.org/docs",
      "og:locale": "en_US",
      "twitter:card": "summary_large_image",
      "twitter:title": "OwnPay Documentation",
      "twitter:description": "Self-hosted payment gateway platform - Multi-brand, 100+ gateways, open source.",
      "twitter:site": "@ownpay",
      "robots": "index, follow, max-snippet:-1, max-image-preview:large"
    }
  },
