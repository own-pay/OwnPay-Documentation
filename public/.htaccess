<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect old installation guide URL to the new one
  RewriteRule ^user-guide/installation(\.html)?$ /getting-started/installation [R=301,L,NC]

  # Redirect any request containing .html extension to its clean URL counterpart (excluding physical files)
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Redirect trailing slash to non-trailing slash if it is not a directory
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [R=301,L]

  # If a directory is requested and it does not have an index.html file, serve the 404 page
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html !-f
  RewriteRule ^ /404.html [L]

  # If the request is not for a physical directory or file
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f

  # If appending .html results in a physical file, rewrite internally to it
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Handle directory index
DirectoryIndex index.html

# Prevent directory listing
Options -Indexes

# Map 403 Forbidden and 404 Not Found to the custom VitePress 404 page
ErrorDocument 403 /404.html
ErrorDocument 404 /404.html

# Cache-Control: prevent stale HTML/clean-URL responses from Nginx proxy_cache and browsers
<IfModule mod_headers.c>
    # Tell Nginx proxy_cache NOT to cache this response
    # X-Accel-Expires: 0 is Nginx's own header - it overrides proxy_cache_valid
    # and prevents the proxy from storing or serving a stale cached copy
    Header set X-Accel-Expires "0"

    # Tell the browser not to cache HTML/clean-URL pages either
    Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"

    # Static assets are content-hashed by VitePress - safe to cache forever
    <FilesMatch "\.(css|js|woff2?|eot|ttf|otf|png|jpg|jpeg|gif|svg|ico|webp)$">
        # Allow Nginx proxy and browser to cache immutable hashed assets
        Header set X-Accel-Expires "31536000"
        Header set Cache-Control "max-age=31536000, public, immutable"
        Header unset Pragma
        Header unset Expires
    </FilesMatch>
</IfModule>
