<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect old installation guide URL to the new one
  RewriteRule ^user-guide/installation(\.html)?$ /getting-started/installation [R=301,L,NC]

  # Redirect any request containing .html extension to its clean URL counterpart (excluding physical files)
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Redirect trailing slash to non-trailing slash if it is not a directory
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [R=301,L]

  # If a directory is requested and it does not have an index.html file, serve the 404 page
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html !-f
  RewriteRule ^ /404.html [L]

  # If the request is not for a physical directory or file
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f

  # If appending .html results in a physical file, rewrite internally to it
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Handle directory index
DirectoryIndex index.html

# Prevent directory listing
Options -Indexes

# Map 403 Forbidden and 404 Not Found to the custom VitePress 404 page
ErrorDocument 403 /404.html
ErrorDocument 404 /404.html

# Cache-Control settings: prevent HTML/clean URL caching, cache hashed assets
<IfModule mod_headers.c>
    # By default, set no-cache for everything (including clean URLs) to prevent stale layouts
    Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"

    # Bypass LiteSpeed server-side cache (fixes "x-cache: HIT from Backend")
    # LiteSpeed is the backend cache on this hosting environment
    Header set X-LiteSpeed-Cache-Control "no-cache"

    # Cache static assets (VitePress assets are hashed and immutable)
    <FilesMatch "\.(css|js|woff2?|eot|ttf|otf|png|jpg|jpeg|gif|svg|ico)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
        Header unset Pragma
        Header unset Expires
        Header unset X-LiteSpeed-Cache-Control
    </FilesMatch>
</IfModule>

# LiteSpeed Cache: disable page caching for HTML/clean-URL responses
# These directives are natively read by the LiteSpeed web server cache module
<IfModule LiteSpeed>
    CacheLookup off
</IfModule>
